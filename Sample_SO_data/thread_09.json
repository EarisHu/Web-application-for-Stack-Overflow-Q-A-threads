          "edited": false,
          "score": 0,
          "creation_date": 1762290411,
          "post_id": 79809111,
          "comment_id": 140836650,
          "content_license": "CC BY-SA 4.0",
          "body": "For the libc <code>open()</code> call, file permissions are optional."
        }

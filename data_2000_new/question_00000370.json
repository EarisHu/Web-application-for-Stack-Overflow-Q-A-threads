        {
            "owner": {
                "profile_image": "https://i.sstatic.net/dfqcw.png?s=256",
                "account_id": 6651855,
                "user_type": "registered",
                "user_id": 5133585,
                "link": "https://stackoverflow.com/users/5133585/sweeper",

                "accept_rate": 75
            },
            "content_license": "CC BY-SA 4.0",
            "score": -2,
            "is_accepted": false,
            "last_activity_date": 1542020268,
            "creation_date": 1542020268,
            "body": "<p>First you are declaring c as char than you are using it as an int <\/p>\n",

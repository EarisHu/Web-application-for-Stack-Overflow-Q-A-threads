            "score": 0,
            "is_accepted": false,
            "last_activity_date": 1565385938,
            "creation_date": 1565385624,
            "body": "<pre><code>public void printReverse(char[] word){\n\nreverseWordMaxIndex = word.length -1;\n\nchar[] reverseWord = new char(reverseWordMaxIndex + 1)\n\nfor ( int i= 0; i &lt; word.length; i++){\n\nreverseWord[reverseWordMaxIndex-i] = word[i];\n\n}\n\nfor( int i= 0; i &lt; reverseWord.length; i++){\n  System.out.println(reverseWord[i]);\n   }\n\n}\n<\/code><\/pre>\n",
            "answer_id": 57437237,

    "answers": [
        {
            "owner": {
                "profile_image": "https://i.sstatic.net/cfKie.jpg?s=256",
                "account_id": 2782706,
                "user_type": "registered",
                "user_id": 2548147,
                "link": "https://stackoverflow.com/users/2548147/raymond-nijland",
                "reputation": 11632,
                "display_name": "Raymond Nijland"
            },
            "content_license": "CC BY-SA 3.0",
            "score": 2,
            "is_accepted": false,
            "last_activity_date": 1508186494,
            "creation_date": 1508186494,
            "body": "<p>The second parameter within the function STR_TO_DATE is using the wrong format.\nYou need to use <code>%d/%m/%Y<\/code> instead of <code>%d-%m-%Y<\/code>because your date is formatted with / seperator.<\/p>\n\n<pre><code>INSERT INTO TABLENAME (DATE) VALUES (STR_TO_DATE('01/01/2010','%d/%m/%Y')); \n<\/code><\/pre>\n",
            "answer_id": 46778774,
            "question_id": 46778607
        },
        {
            "owner": {
                "profile_image": "https://i.sstatic.net/OFHMz.jpg?s=256",
                "account_id": 4563058,
                "user_type": "registered",
                "user_id": 3704831,
                "link": "https://stackoverflow.com/users/3704831/wogsland",
                "reputation": 9541,
                "display_name": "wogsland",
                "accept_rate": 78
            },
            "content_license": "CC BY-SA 3.0",
            "score": 0,
            "is_accepted": false,
            "last_activity_date": 1508243094,
            "creation_date": 1508186319,
            "body": "<p><code>STR_TO_DATE<\/code> requires the formatting of the strings to match:<\/p>\n\n<pre><code>INSERT INTO TABLENAME (DATE) VALUES (STR_TO_DATE('01/01/2010','%d/%m/%Y'));\n<\/code><\/pre>\n\n<p>Refer to the <a href=\"https://dev.mysql.com/doc/refman/5.7/en/date-and-time-functions.html#function_str-to-date\" rel=\"nofollow noreferrer\">docs<\/a> for full details.<\/p>\n",

            },
            "content_license": "CC BY-SA 3.0",
            "score": 0,
            "is_accepted": true,
            "last_activity_date": 1494027399,
            "creation_date": 1494027399,
            "body": "<p>Use <\/p>\n\n<pre><code>isRange(mMyLatitude, mMyLongitude, mPoi.getPoiLatitude(), mPoi.getPoiLongitude)\n<\/code><\/pre>\n\n<p>instead of <\/p>\n\n<pre><code>isRange(MyLatitude, MyLongitude, MpoiLatitude, MpoiLongitude)\n<\/code><\/pre>\n\n<p><strong>FYI,<\/strong> its better to use small letter for naming variable.<\/p>\n",

                "accept_rate": 84
            },
            "content_license": "CC BY-SA 3.0",
            "score": 3,
            "is_accepted": false,
            "last_activity_date": 1362659915,
            "creation_date": 1362659550,
            "body": "<p>Try this:<\/p>\n\n<pre><code>String[] array = \"1,2,3,4,5\".split(\",\");\nint[] result = new result[array.length];\nfor (int i = 0; i &lt; array.length; i++) {\n    try {\n         result[i] = Integer.parseInt(array[i]);\n    } catch (NumberFormatException nfe) {};\n}\n<\/code><\/pre>\n",
            "answer_id": 15271334,
            "question_id": 15271306,
            "last_edit_date": 1362659915
        },
        {
            "owner": {
                "profile_image": "https://i.sstatic.net/ODFpP.jpg?s=256",
                "account_id": 1229114,
                "user_type": "registered",
                "user_id": 1194067,
                "link": "https://stackoverflow.com/users/1194067/jeevan-patil",
                "reputation": 6079,
                "display_name": "Jeevan Patil",
                "accept_rate": 73
            },
            "content_license": "CC BY-SA 3.0",
            "score": 1,
            "is_accepted": false,
            "last_activity_date": 1420465639,
            "creation_date": 1362659550,
            "body": "<p>Use StringTokenizer which will split string by comma and then put those values/tokens in array of integers.<\/p>\n\n<pre><code>public static int[] getIntegers(String numbers) {\n    StringTokenizer st = new StringTokenizer(numbers, \",\");\n    int[] intArr = new int[st.countTokens()];\n    int i = 0;\n    while (st.hasMoreElements()) {\n        intArr[i] = Integer.parseInt((String) st.nextElement());\n        i++;\n    }\n    return intArr;\n}\n<\/code><\/pre>\n",
            "answer_id": 15271335,
            "question_id": 15271306,
            "last_edit_date": 1420465639
        },

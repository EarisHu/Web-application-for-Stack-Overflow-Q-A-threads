        {
            "owner": {
                "profile_image": "https://www.gravatar.com/avatar/c511b8308fa9283d79d466f21f8bb43a?s=256&d=identicon&r=PG",
                "account_id": 1910014,
                "user_type": "registered",
                "user_id": 1724085,
                "link": "https://stackoverflow.com/users/1724085/andrew-templeton",

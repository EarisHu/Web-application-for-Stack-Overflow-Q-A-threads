    "answers": [
        {
            "owner": {
                "profile_image": "https://www.gravatar.com/avatar/cf6d0868b2b4c69bac3e6f265a32b6a7?s=256&d=identicon&r=PG",
                "account_id": 37536,
                "user_type": "registered",
                "user_id": 107331,
                "link": "https://stackoverflow.com/users/107331/daniel-martin",
                "reputation": 23658,
                "display_name": "Daniel Martin",
                "accept_rate": 80

    "question_comments": [],
    "answers": [
        {
            "owner": {
                "profile_image": "https://www.gravatar.com/avatar/6261c8ab215b8069e8290516c80445d8?s=256&d=identicon&r=PG",
                "account_id": 22086,
                "user_type": "registered",
                "user_id": 54200,
                "link": "https://stackoverflow.com/users/54200/kevindtimm",
                "reputation": 14406,
                "display_name": "KevinDTimm",
                "accept_rate": 83
            },
            "content_license": "CC BY-SA 2.5",

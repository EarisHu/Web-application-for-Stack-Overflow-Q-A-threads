            "content_license": "CC BY-SA 3.0",
            "score": 2,
            "is_accepted": false,
            "last_activity_date": 1351070029,
            "creation_date": 1351070029,
            "body": "<p>I just add one extra hidden radio-button to every group and select that one when i want to clear all buttonsGroup.<\/p>\n\n<pre><code>public void actionCommandCLEAR() {\n        hiddenTime.setSelected(true);\n        hiddenDate.setSelected(true);\n        hiddenDoc.setSelected(true);\n        hiddenSoc.setSelected(true);\n        hiddenLand.setSelected(true);\n    }\n<\/code><\/pre>\n",
            "answer_id": 13046178,

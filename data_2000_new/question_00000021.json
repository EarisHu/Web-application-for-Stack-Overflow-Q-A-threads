        "owner": {
            "profile_image": "https://i.sstatic.net/9YAqp.jpg?s=256",
            "account_id": 465479,
            "user_type": "registered",
            "user_id": 869594,
            "link": "https://stackoverflow.com/users/869594/florin-bombeanu",

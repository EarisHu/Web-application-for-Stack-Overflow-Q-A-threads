{
    "question": {
        "owner": {
            "profile_image": "https://www.gravatar.com/avatar/1d51e358999bd31439d3810486942e9b?s=256&d=identicon&r=PG",
            "account_id": 416369,
            "user_type": "registered",
            "user_id": 791713,
            "link": "https://stackoverflow.com/users/791713/niklas-r",

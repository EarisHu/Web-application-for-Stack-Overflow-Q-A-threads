            "content_license": "CC BY-SA 2.5",
            "score": 0,
            "is_accepted": false,
            "last_activity_date": 1278599906,
            "creation_date": 1278599906,
            "body": "<p>Yes, definitely.  I found that data I stored in instance variables could not be accessed between tests due to this design.<\/p>\n",
            "answer_id": 3204729,

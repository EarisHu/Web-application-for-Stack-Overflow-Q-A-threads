        "answer_count": 11,
        "title": "For a boolean field, what is the naming convention for its getter/setter?",
        "body": "<p>Eg.<\/p>\n\n<pre><code>boolean isCurrent = false;\n<\/code><\/pre>\n\n<p>What do you name its getter and setter?<\/p>\n",
        "question_id": 5322648,
        "tags": [
            "java",
            "coding-style",
            "naming-conventions",
            "javabeans"
        ],
        "score": 248,
        "accepted_answer_id": 5322666,
        "is_answered": true,
        "view_count": 297098,
        "last_edit_date": 1361377098
    },
    "question_comments": [{
        "owner": {

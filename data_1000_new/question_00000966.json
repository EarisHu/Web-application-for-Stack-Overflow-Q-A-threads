        {
            "owner": {
                "profile_image": "https://www.gravatar.com/avatar/4cf74649b70fc946650115e0d5067ebe?s=256&d=identicon&r=PG",
                "account_id": 1328773,
                "user_type": "registered",
                "user_id": 1273080,
                "link": "https://stackoverflow.com/users/1273080/petr-jane%c4%8dek",

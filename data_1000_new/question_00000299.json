        "owner": {
            "profile_image": "https://www.gravatar.com/avatar/9b31b9d123bff80f00317a1df0dd00e2?s=256&d=identicon&r=PG",
            "account_id": 9963,
            "user_type": "registered",
            "user_id": 18627,
            "link": "https://stackoverflow.com/users/18627/alex-ott",
            "reputation": 88119,
            "display_name": "Alex Ott"

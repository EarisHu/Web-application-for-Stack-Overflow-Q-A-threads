        "owner": {
            "profile_image": "https://i.sstatic.net/pgHgd.jpg?s=256",
            "account_id": 3052937,
            "user_type": "registered",
            "user_id": 2587166,
            "link": "https://stackoverflow.com/users/2587166/luca-basso-ricci",

        {
            "owner": {
                "profile_image": "https://i.sstatic.net/iTfit.jpg?s=256",
                "account_id": 10068177,
                "user_type": "registered",
                "user_id": 7442673,
                "link": "https://stackoverflow.com/users/7442673/m-raynal-bye-toxic-community",

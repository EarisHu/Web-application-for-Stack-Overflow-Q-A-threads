    "answers": [
        {
            "owner": {
                "profile_image": "https://i.sstatic.net/CId7Y.jpg?s=256",
                "account_id": 2973802,
                "user_type": "registered",
                "user_id": 2525313,
                "link": "https://stackoverflow.com/users/2525313/nicolai-parlog",
                "reputation": 51708,
                "display_name": "Nicolai Parlog",
                "accept_rate": 88

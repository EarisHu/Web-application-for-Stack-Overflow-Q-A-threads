    "answers": [
        {
            "owner": {
                "profile_image": "https://www.gravatar.com/avatar/f83cc994c98e417a3e0e0971c0480293?s=256&d=identicon&r=PG",
                "account_id": 2102673,
                "user_type": "registered",
                "user_id": 1869846,
                "link": "https://stackoverflow.com/users/1869846/ruchira-gayan-ranaweera",

        "owner": {
            "profile_image": "https://i.sstatic.net/tFJnM.png?s=256",
            "account_id": 4680959,
            "user_type": "registered",
            "user_id": 3789686,
            "link": "https://stackoverflow.com/users/3789686/gopal-singh-sirvi",

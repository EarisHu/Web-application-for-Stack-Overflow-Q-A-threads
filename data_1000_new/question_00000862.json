                "display_name": "Bhavinkumar Patel",
                "accept_rate": 50
            },
            "content_license": "CC BY-SA 3.0",
            "score": 0,
            "is_accepted": false,
            "last_activity_date": 1458970761,
            "creation_date": 1458970761,
            "body": "<p><strong><em>Change<\/em><\/strong><\/p>\n\n<pre><code>app:layout_scrollFlags=\"scroll|exituntilcollapse\"\n<\/code><\/pre>\n\n<p><strong><em>instead of<\/em><\/strong><\/p>\n\n<pre><code>app:layout_scrollFlags=\"scroll|enterAlways\"\n<\/code><\/pre>\n",
            "answer_id": 36232003,
            "question_id": 36231888
        },
        {

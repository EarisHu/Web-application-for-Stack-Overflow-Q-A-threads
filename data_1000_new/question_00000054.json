        },
        {
            "owner": {
                "profile_image": "https://i.sstatic.net/gqNqv.jpg?s=256",
                "account_id": 288238,
                "user_type": "registered",
                "user_id": 588532,
                "link": "https://stackoverflow.com/users/588532/uriel-frankel",
                "reputation": 14674,
                "display_name": "Uriel Frankel",
                "accept_rate": 88
            },
            "content_license": "CC BY-SA 3.0",
            "score": 1,
            "is_accepted": false,
            "last_activity_date": 1406739763,
            "creation_date": 1406739763,
            "body": "<p>For everyone that has Android problems in the string.xml, use \\'\\' instead of single quote.<\/p>\n",
            "answer_id": 25042752,

                "accept_rate": 69
            },
            "content_license": "CC BY-SA 2.5",
            "score": 2,
            "is_accepted": false,
            "last_activity_date": 1292415904,
            "creation_date": 1292415904,
            "body": "<p>Consider using Properties Editor plugin (for Eclipse)<\/p>\n\n<p><a href=\"http://propedit.sourceforge.jp/index_en.html\" rel=\"nofollow\">http://propedit.sourceforge.jp/index_en.html<\/a><\/p>\n",
            "answer_id": 4449830,

        "is_accepted": false,
        "last_activity_date": 1562377239,
        "creation_date": 1562377239,
        "body": "<pre><code>public static void printBiggerMinLevel(Node root, int k) {//Using BFS \n        int chosen = 0, level = Integer.MAX_VALUE;\n        if(root == null) return;\n        if(root.getVal() &gt; k) {\n            System.out.println(root.getVal());\n            return;\n        }\n        Queue&lt;Node&gt; q = new Queue&lt;&gt;();\n        q.enqueue(root);\n        Node cur;\n        while(!q.isEmpty()) {\n            cur = q.dequeue();\n            if(cur.getVal() &gt; k)\n                if(cur.getLevel() &lt; level) {\n                    chosen = cur.getVal();\n                    level = cur.getLevel();\n                }\n            if(cur.getLeftSon() != null)\n                q.enqueue(cur.getLeftSon());\n            if(cur.getRightSon() != null)\n                q.enqueue(cur.getRightSon());\n        }\n        System.out.println(chosen);\n    }\n<\/code><\/pre>\n",

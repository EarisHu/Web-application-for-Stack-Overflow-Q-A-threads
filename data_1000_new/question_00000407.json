    "answers": [{
        "owner": {
            "profile_image": "https://www.gravatar.com/avatar/bedab8d59cdd9ca2366251c11df4795e?s=256&d=identicon&r=PG&f=y&so-version=2",
            "account_id": 7595189,
            "user_type": "registered",
            "user_id": 5761558,
            "link": "https://stackoverflow.com/users/5761558/ernest-k",
            "reputation": 45490,
            "display_name": "ernest_k"
        },
        "content_license": "CC BY-SA 4.0",
